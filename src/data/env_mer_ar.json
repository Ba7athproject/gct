    "text_blocks": [
        {
            "id": "contexte_court",
            "title": "ما تظهره البيانات",
            "body": "تظهر الدراسات حول خليج قابس تراجعاً مذهلاً في مروج البوسيدونيا منذ السبعينيات، بالتوازي مع مفرغات هائلة من الفوسفوجبس والنفايات الصناعية. يترجم هذا الاختفاء بفقدان هام للتنوع البيولوجي القاعي، وانخفاض في المخزون السمكي الساحلي، وخسائر اقتصادية تقدر بعشرات ملايين الأورو سنوياً للصيد التقليدي."
        }
    ]
